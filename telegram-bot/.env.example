# ============================================
# FinTechTerms Telegram Bot — Environment Variables
# Copy this file to .env and fill in the values.
# ============================================

# ── Telegram ──────────────────────────────────
# Bot token from @BotFather (required)
# Type: string — e.g. "123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11"
BOT_TOKEN=

# Telegram user ID for admin features (optional, integer)
# Get your ID from @userinfobot
ADMIN_USER_ID=0

# ── Supabase ──────────────────────────────────
# Supabase project URL (required)
# Type: string — e.g. "https://abcdefghij.supabase.co"
SUPABASE_URL=https://your-project.supabase.co

# Supabase ANON key used by the bot for term lookup (required).
# Type: string — starts with "eyJ..."
SUPABASE_ANON_KEY=<your-supabase-anon-key>

# Public FinTechTerms web app URL used in bot deep links (required)
WEB_APP_URL=<your-web-app-url>

# Optional Redis URL for distributed rate limiting. Local development falls back
# to the bot's in-memory limiter.
REDIS_URL=

# Sentry DSN for bot-side runtime error capture.
# Optional for local development.
# Required when RENDER=1 / production-style Render runtime validation is used.
BOT_SENTRY_DSN=

# ── Bot Defaults ──────────────────────────────
# Default interface language: ru | en | tr
DEFAULT_LANGUAGE=ru

# Hour to send daily term (0-23, UTC)
DAILY_TERM_HOUR=9
