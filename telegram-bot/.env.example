# ============================================
# FinTechTerms Telegram Bot — Environment Variables
# Copy this file to .env and fill in the values.
# ============================================

# ── Telegram ──────────────────────────────────
# Bot token from @BotFather (required)
# Type: string — e.g. "123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11"
BOT_TOKEN=

# Telegram user ID for admin features (optional, integer)
# Get your ID from @userinfobot
ADMIN_USER_ID=0

# ── Supabase ──────────────────────────────────
# Supabase project URL (required)
# Type: string — e.g. "https://abcdefghij.supabase.co"
SUPABASE_URL=https://hdhytostmmrvwuluogpq.supabase.co

# Use the ANON key by default. For privileged account lookups, set
# SUPABASE_SERVICE_ROLE_KEY separately below (never commit/expose it).
# Type: string — starts with "eyJ..."
SUPABASE_KEY=

# Optional but recommended for server-side bot account features (favorites/stats/link checks).
# If empty, bot falls back to SUPABASE_KEY and can be restricted by RLS policies.
SUPABASE_SERVICE_ROLE_KEY=

# ── Bot Defaults ──────────────────────────────
# Default interface language: ru | en | tr
DEFAULT_LANGUAGE=ru

# Hour to send daily term (0-23, UTC)
DAILY_TERM_HOUR=9
