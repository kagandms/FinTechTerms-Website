{
  "name": "fintechterms",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "typecheck": "tsc --project tsconfig.check.json --noEmit",
    "lint": "eslint app components contexts hooks lib types utils proxy.ts scripts --ext .js,.jsx,.ts,.tsx --max-warnings 0",
    "test": "jest",
    "audit:seo": "node scripts/lighthouse-seo-budget.mjs",
    "test:e2e:guest": "playwright test --grep-invert @auth-required",
    "test:e2e:auth": "playwright test --grep @auth-required",
    "smoke:staging": "node scripts/staging-smoke.mjs",
    "validate:runtime-env": "node scripts/validate-runtime-env.mjs",
    "validate:release-gate-env": "node scripts/validate-release-gate-env.mjs",
    "validate:release-env": "node scripts/validate-release-env.mjs",
    "verify:sql-sources": "node scripts/verify-sql-sources.mjs",
    "verify:bootstrap-db": "bash scripts/verify-bootstrap-db.sh",
    "verify:release-db": "node scripts/verify-release-db.mjs",
    "test:watch": "jest --watch",
    "prepare": "command -v husky >/dev/null 2>&1 && husky || true"
  },
  "overrides": {
    "picomatch": "^4.0.4",
    "yaml": "^2.8.3",
    "glob": {
      ".": "^10.5.0",
      "minimatch": "^9.0.7"
    },
    "flatted": "^3.4.0",
    "source-map": "^0.7.4",
    "sourcemap-codec": "npm:@jridgewell/sourcemap-codec",
    "test-exclude": {
      "minimatch": "^3.1.5"
    }
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@sentry/nextjs": "^10.43.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.90.1",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "lucide-react": "^0.400.0",
    "next": "^16.1.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.71.2",
    "recharts": "^3.6.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.7",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "lint-staged": "^16.2.7",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
