# ============================================
# FinTechTerms Repository Environment Catalog
# ============================================
#
# Root web app and repo-level scripts:
#   cp .env.example .env.local
#
# Telegram bot runtime:
#   cp telegram-bot/.env.example telegram-bot/.env
#
# This file lists every environment variable consumed anywhere in the repo so
# the documented surface stays complete, even when a variable belongs in
# telegram-bot/.env instead of the root .env.local file.

# ── Web App / Shared Scripts ───────────────────────────────

# Public site origin used for canonical URLs, metadata, sitemap, and SEO markup.
# Required for production builds and runtime. Development falls back only to the
# explicit dev-only constant http://localhost:3000.
NEXT_PUBLIC_SITE_URL=https://your-domain.example

# Public default UI language used when no language cookie or browser preference
# is available. Allowed values: ru | en | tr
NEXT_PUBLIC_DEFAULT_LANGUAGE=ru

# Supabase project URL used by the Next.js app and data scripts.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon key used by the web app.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Service role key for privileged server-side admin flows.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Alias used by scripts/run_schema_update.py. In most setups this should match
# SUPABASE_SERVICE_ROLE_KEY.
SUPABASE_SERVICE_KEY=your_service_role_key_here

# Legacy URL alias still consumed by some maintenance scripts.
SUPABASE_URL=https://your-project.supabase.co

# Admin-only dashboard guard.
ADMIN_EMAIL=admin@example.com

# Client-visible admin email used for UI conditionals.
NEXT_PUBLIC_ADMIN_EMAIL=admin@example.com

# Optional Google Analytics measurement ID.
NEXT_PUBLIC_GA_ID=

# Optional Sentry browser/server DSN.
NEXT_PUBLIC_SENTRY_DSN=

# Optional public-facing Sentry environment label.
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development

# Optional trace sampling rate between 0 and 1.
SENTRY_TRACES_SAMPLE_RATE=0.1

# Optional Sentry source map upload credentials for CI/CD.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Local Playwright credentials for the authenticated E2E flow.
E2E_AUTH_EMAIL=e2e-user@example.com
E2E_AUTH_PASSWORD=change_me

# ── Telegram Bot Runtime (telegram-bot/.env) ──────────────

# Telegram bot token from @BotFather.
BOT_TOKEN=

# Public web app URL used in bot deep links.
WEB_APP_URL=https://your-domain.example

# Supabase anon key used by the Telegram bot runtime.
SUPABASE_ANON_KEY=your_anon_key_here

# Optional Redis URL used for bot rate limiting.
REDIS_URL=

# Optional Telegram admin user ID for privileged bot actions.
ADMIN_USER_ID=0

# Bot default interface language. Allowed values: ru | en | tr
DEFAULT_LANGUAGE=ru

# Bot daily term dispatch hour in UTC. Allowed values: 0-23
DAILY_TERM_HOUR=9

# ── Platform / CI Provided Variables ──────────────────────
#
# These are consumed in code but are normally set by the host or CI system.
# Keep them documented here so the env surface is complete; do not copy them
# into local .env files unless you are explicitly emulating that environment.

CI=
NODE_ENV=development
PORT=8080
RENDER=
RENDER_EXTERNAL_URL=

# Preview/staging smoke inputs used by CI release gates.
STAGING_BASE_URL=
SUPABASE_DB_URL=
SMOKE_AUTH_EMAIL=
SMOKE_AUTH_PASSWORD=
SENTRY_SMOKE_EMAIL=
SENTRY_SMOKE_PASSWORD=
VERCEL_AUTOMATION_BYPASS_SECRET=
