# ============================================
# FinTechTerms Web App — Environment Variables
# Copy this file to .env.local and fill in the values.
# ============================================

# ── Supabase ──────────────────────────────────
# Public base URL used for canonical links, metadata, sitemap, and client-side SEO markup.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Your Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# ⚠️  Use the ANON (public) key — safe for client-side, respects RLS
# NEVER use the service_role key here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Server-side only. Required for privileged server/admin flows.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Script-only service key used by scripts/run_schema_update.py.
SUPABASE_SERVICE_KEY=your_service_role_key_here

# Used for admin-only UI/API guards.
ADMIN_EMAIL=

# Exposed to client for UI conditional rendering.
NEXT_PUBLIC_ADMIN_EMAIL=

# ── Google Analytics (optional) ───────────────
# GA4 Measurement ID — e.g. "G-XXXXXXXXXX"
NEXT_PUBLIC_GA_ID=

# ── Google Search Console (optional) ──────────
# Verification token for Google Search Console
NEXT_PUBLIC_GOOGLE_VERIFICATION=
